generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // For migrations and introspection we prefer the direct DB connection from
  // Supabase (DIRECT_URL). The runtime app can keep using the pooled
  // `DATABASE_URL` (pooler). Set DIRECT_URL in your .env to the "Direct
  // connection" URI from Supabase and Prisma commands will use it.
  url      = env("DIRECT_URL")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String?
  fullName    String?
  avatarUrl   String?
  githubId    String   @unique
  githubAccessToken String?
  githubRefreshToken String?
  githubAccessTokenExpiresAt DateTime?
  githubRefreshTokenExpiresAt DateTime?
  githubTokenValid Boolean @default(true)
  githubConnectedAt DateTime?
  requestedScopes    String?
  canReadUser        Boolean  @default(false)
  canReadEmail       Boolean  @default(false)
  canReadRepos       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
