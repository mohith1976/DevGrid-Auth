{
  "name": "devgrid-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:prod": "node dist/main.js",
    "prisma:pull-direct": "node ./scripts/prisma-direct.js",
    "prisma:migrate-direct": "node ./scripts/prisma-migrate-direct.js"
  },
  "dependencies": {
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@prisma/client": "^5.0.0",
    "@aws-sdk/client-s3": "^3.460.0",
    "@aws-sdk/s3-request-presigner": "^3.460.0",
    "axios": "^1.0.0",
    "ioredis": "^5.3.2",
    "dotenv": "^16.0.0",
    "jsonwebtoken": "^9.0.0",
    
    "mongoose": "^7.0.0",
    "prisma": "^5.0.0",
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "ts-node": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
